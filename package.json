{
  "name": "nexterm",
  "version": "0.2.0",
  "description": "NexTerm – A modern, feature-rich terminal for Windows",
  "author": "Rajendra Pandey <rajendrapandey199971@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/rajendrapandey/NexTerm",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@xterm/addon-image": "^0.9.0",
    "better-sqlite3": "^9.4.3",
    "js-yaml": "^4.1.1",
    "koffi": "^2.16.1",
    "node-pty": "^1.0.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "com.nexterm.app",
    "productName": "NexTerm",
    "copyright": "Copyright © 2026 Rajendra Pandey",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/*.{ts,tsx,map,d.ts}",
      "!**/*.{md,markdown,txt}",
      "!**/{test,tests,__tests__,docs,example,examples,coverage}/**",
      "!**/.{git,github,vscode,idea}/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/ssh2/**/*",
      "node_modules/cpu-features/**/*",
      "node_modules/koffi/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NexTerm-Setup-${version}.${ext}",
      "executableName": "NexTerm"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NexTerm",
      "uninstallDisplayName": "NexTerm",
      "differentialPackage": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp"
    }
  }
}
